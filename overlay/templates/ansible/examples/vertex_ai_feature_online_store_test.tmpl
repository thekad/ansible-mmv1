- name: Test case
  block:
    - name: Create Feature Online Store
      google.cloud.gcp_vertexai_feature_online_store:
        state: present
        name: "{{`{{ resource_name | regex_replace('-', '_') }}`}}"
        bigtable:
          auto_scaling:
            min_node_count: 1
            max_node_count: 3
            cpu_utilization_target: 50
        region: us-central1
        labels:
          env: ci
        project: "{{`{{ gcp_project }}`}}"
        auth_kind: "{{`{{ gcp_cred_kind }}`}}"
        service_account_file: "{{`{{ gcp_cred_file }}`}}"
      register: _myfos

    - name: Fetch Feature Online Store info
      google.cloud.gcp_vertexai_feature_online_store_info:
        region: us-central1
        filters:
          - labels.env = "ci"
        project: "{{`{{ gcp_project }}`}}"
        auth_kind: "{{`{{ gcp_cred_kind }}`}}"
        service_account_file: "{{`{{ gcp_cred_file }}`}}"
      register: _myfos_info

    - name: Run assertions
      ansible.builtin.assert:
        that:
          - _myfos.changed
          - _myfos_info.resources | length >= 1

  always:
    - name: Delete Feature Online Store
      google.cloud.gcp_vertexai_feature_online_store:
        state: absent
        name: "{{`{{ resource_name | regex_replace('-', '_') }}`}}"
        bigtable:
          auto_scaling:
            min_node_count: 1
            max_node_count: 3
            cpu_utilization_target: 50
        region: us-central1
        project: "{{`{{ gcp_project }}`}}"
        auth_kind: "{{`{{ gcp_cred_kind }}`}}"
        service_account_file: "{{`{{ gcp_cred_file }}`}}"
