- name: Test case
  block:
    - name: Create Full Runtime Template
      google.cloud.gcp_colab_runtime_template:
        name: "{{`{{ resource_name }}-rtt`}}"
        display_name: "{{`{{ resource_name }}-rtt`}}"
        state: present
        location: us-central1
        machine_spec:
          machine_type: n1-standard-2
          accelerator_type: NVIDIA_TESLA_T4
          accelerator_count: 1
        network_spec:
          enable_internet_access: true
          network: "projects/{{`{{ gcp_project }}`}}/global/networks/{{`{{ _network.name }}`}}"
        project: "{{`{{ gcp_project }}`}}"
        auth_kind: "{{`{{ gcp_cred_kind }}`}}"
        service_account_file: "{{`{{ gcp_cred_file }}`}}"
      register: _myrt

    - name: Run assertions
      ansible.builtin.assert:
        that:
          - _myrt.changed == true

  always:
    - name: Delete Runtime Template
      google.cloud.gcp_colab_runtime_template:
        name: "{{`{{ resource_name }}-rtt`}}"
        state: absent
        display_name: "{{`{{ resource_name }}-rtt`}}"
        location: us-central1
        project: "{{`{{ gcp_project }}`}}"
        auth_kind: "{{`{{ gcp_cred_kind }}`}}"
        service_account_file: "{{`{{ gcp_cred_file }}`}}"