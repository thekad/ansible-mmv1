- name: Test case
  block:
    - name: Create primary alloydb cluster
      google.cloud.gcp_alloydb_cluster:
        cluster_id: "{{`{{ resource_name }}`}}-primary"
        state: present
        location: us-central1
        cluster_type: PRIMARY
        initial_user:
          user: pgroot
          password: Test123Test
        network_config:
          network: "projects/{{`{{ gcp_project_number }}`}}/global/networks/{{`{{ resource_name }}`}}"
        project: "{{`{{ gcp_project }}`}}"
        auth_kind: "{{`{{ gcp_cred_kind }}`}}"
        service_account_file: "{{`{{ gcp_cred_file }}`}}"
      register: _primary

    - name: Fetch primary cluster info
      google.cloud.gcp_alloydb_cluster_info:
        location: us-central1
        filters:
          - name = "{{`{{ _primary.name }}`}}"
        project: "{{`{{ gcp_project }}`}}"
        auth_kind: "{{`{{ gcp_cred_kind }}`}}"
        service_account_file: "{{`{{ gcp_cred_file }}`}}"
      register: _primary_info

    - name: Create secondary cluster attached to primary
      google.cloud.gcp_alloydb_cluster:
        cluster_id: "{{`{{ resource_name }}`}}-secondary"
        state: present
        location: us-central1
        cluster_type: SECONDARY
        network_config:
          network: "projects/{{`{{ gcp_project_number }}`}}/global/networks/{{`{{ resource_name }}`}}"
        secondary_config:
          primary_cluster_name: "{{`{{ _primary.name }}`}}"
        project: "{{`{{ gcp_project }}`}}"
        auth_kind: "{{`{{ gcp_cred_kind }}`}}"
        service_account_file: "{{`{{ gcp_cred_file }}`}}"
      register: _secondary

    - name: Fetch secondary cluster info
      google.cloud.gcp_alloydb_cluster_info:
        location: us-central1
        filters:
          - name = "{{`{{ _secondary.name }}`}}"
        project: "{{`{{ gcp_project }}`}}"
        auth_kind: "{{`{{ gcp_cred_kind }}`}}"
        service_account_file: "{{`{{ gcp_cred_file }}`}}"
      register: _secondary_info

    - name: Run assertions
      ansible.builtin.assert:
        that:
          - _primary.changed == true
          - _primary.clusterType == "PRIMARY"
          - _secondary.changed == true
          - _secondary.clusterType == "SECONDARY"
          - _secondary.secondaryConfig.primaryClusterName.split('/')[-1] == _primary.name.split('/')[-1]
          - _primary_info.resources | length == 1
          - _secondary_info.resources | length == 1

  always:
    - name: Delete secondary cluster
      google.cloud.gcp_alloydb_cluster:
        cluster_id: "{{`{{ resource_name }}`}}-secondary"
        state: absent
        location: us-central1
        project: "{{`{{ gcp_project }}`}}"
        auth_kind: "{{`{{ gcp_cred_kind }}`}}"
        service_account_file: "{{`{{ gcp_cred_file }}`}}"

    - name: Delete primary cluster
      google.cloud.gcp_alloydb_cluster:
        cluster_id: "{{`{{ resource_name }}`}}-primary"
        state: absent
        location: us-central1
        project: "{{`{{ gcp_project }}`}}"
        auth_kind: "{{`{{ gcp_cred_kind }}`}}"
        service_account_file: "{{`{{ gcp_cred_file }}`}}"
